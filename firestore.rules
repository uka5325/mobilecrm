rules_version = '2';

// ─────────────────────────────────────────────────────────────────────────────
// MobileCRM Firestore 보안 규칙
//
// 설계 원칙:
//  1. 데이터 변경 API(/api/*)는 firebase-admin SDK를 쓰므로 "규칙을 우회"한다.
//     따라서 클라이언트 SDK가 실제로 직접 접근하는 컬렉션만 개방하고,
//     서버(admin)만 다루는 컬렉션은 클라이언트 직접 접근을 전면 차단한다.
//  2. 인증된 직원에 대한 실제 마지막 방어선은 이 규칙이다.
//     (NEXT_PUBLIC_* 설정이 공개되어 직원이 client SDK로 직접 붙을 수 있음)
//
// 클라이언트 SDK 직접 접근 컬렉션 (이 파일에서 개방):
//   - reservations         : 실시간 onSnapshot 읽기 + 의사명 일괄변경(admin) 쓰기
//   - staff                : 의사목록/이메일/설정 읽기, 직원관리 쓰기(admin)
//   - reservationPhotos     : 사진 CRUD
//   - reservationCharts     : 상담차트 CRUD
//   - conferenceMemos       : 실시간 onSnapshot 읽기 전용(쓰기는 /api/settings 경유)
// 그 외 컬렉션은 모두 admin API 경유 → 클라이언트 직접 접근 차단.
//
// 3. 행(row) 단위 권한 분리는 의도적으로 두지 않았다. isActiveStaff()만 통과하면
//    role(admin/coordinator/staff/interpreter) 구분 없이 위 컬렉션들을 볼 수 있다.
//    상담회/병원 운영 특성상 전 직원이 전체 일정·직원목록·사진/차트/메모를 봐야 하므로
//    버그가 아니라 의도된 설계다. "본인 담당 건만" 같은 요구가 생기면 그때 좁힌다.
// ─────────────────────────────────────────────────────────────────────────────

service cloud.firestore {
  match /databases/{database}/documents {

    function staffDoc() {
      return get(/databases/$(database)/documents/staff/$(request.auth.uid));
    }

    function isActiveStaff() {
      return request.auth != null
        && exists(/databases/$(database)/documents/staff/$(request.auth.uid))
        && staffDoc().data.active == true;
    }

    // active 검사를 포함 → 비활성화된 admin은 권한을 잃는다.
    function isAdmin() {
      return isActiveStaff() && staffDoc().data.role == "admin";
    }

    // ── 직원 정보 ──────────────────────────────────────────────────────────
    match /staff/{userId} {
      allow read: if isActiveStaff();
      allow create, update: if isAdmin();
      allow delete: if false;
    }

    // ── 예약 (실시간 읽기 + 의사명 일괄변경 쓰기) ───────────────────────────
    // 생성/일반 수정(예약금·상태·담당 등)은 전부 /api/reservations(admin SDK) 경유.
    // 클라 직접 update는 settings의 의사명 일괄변경(admin 전용) 단 하나의 흐름만 허용하고,
    // 그마저도 doctors 필드만 바꿀 수 있게 화이트리스트로 좁힌다.
    // (예전엔 isActiveStaff()만 검사해 모든 active 직원이 임의 필드를 감사로그 없이
    //  바꿀 수 있었다 — admin + 필드 화이트리스트로 강화.)
    match /reservations/{id} {
      allow read: if isActiveStaff();
      allow create: if false;
      allow update: if isAdmin()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["doctors"]);
      allow delete: if false;
    }

    // ── 예약 사진 ──────────────────────────────────────────────────────────
    match /reservationPhotos/{id} {
      allow read: if isActiveStaff();
      allow create: if isActiveStaff()
        && request.resource.data.uploadedByUid == request.auth.uid;
      // 소프트삭제/감사 필드만 허용 — uploadedByUid/patientId/reservationId 등 신원·연결 필드 변조 차단
      allow update: if isActiveStaff()
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(["isDeleted", "deletedAt", "deletedBy", "deletedByUid", "updatedAt", "updatedBy", "updatedByUid"]);
      allow delete: if false;
    }

    // ── 상담차트 ───────────────────────────────────────────────────────────
    match /reservationCharts/{id} {
      allow read: if isActiveStaff();
      allow create: if isActiveStaff()
        && request.resource.data.createdByUid == request.auth.uid;
      // 차트 이미지 갱신 + 소프트삭제 필드만 허용 — createdByUid 등 신원 필드 변조 차단
      allow update: if isActiveStaff()
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(["chartUrl", "storagePath", "updatedAt", "updatedBy", "updatedByUid", "isDeleted", "deletedAt"]);
      allow delete: if false;
    }

    // ── 오늘의 전체 메모 (실시간 읽기만 — 쓰기는 전부 /api/settings 경유) ────
    // add_memo/update_memo/delete_memo는 requireActiveStaff만 검사하고 role 제한이
    // 없다(전 직원 공용 게시판 성격) — 클라 직접 읽기를 여는 것도 같은 권한이라
    // 새 노출이 아니다. 쓰기는 신원(createdBy)·소프트삭제 감사 필드를 서버에서
    // 강제해야 하므로 admin API 전용을 유지한다.
    match /conferenceMemos/{id} {
      allow read: if isActiveStaff();
      allow write: if false;
    }

    // ── 서버(admin SDK) 전용 — 클라이언트 직접 접근 전면 차단 ───────────────
    // admin SDK는 규칙을 우회하므로 아래 차단이 API 동작에 영향을 주지 않는다.
    match /invoices/{id}                  { allow read, write: if false; }
    match /logs/{id}                      { allow read, write: if false; }
    match /patients/{id}                  { allow read, write: if false; }
    match /reservationNotes/{id}          { allow read, write: if false; }
    match /notes/{id}                     { allow read, write: if false; }
    match /invoiceTemplates/{id}          { allow read, write: if false; }
    match /invoiceTemplateSections/{id}   { allow read, write: if false; }
    match /invoiceItems/{id}              { allow read, write: if false; }
    match /invoiceCategories/{id}         { allow read, write: if false; }
    match /appSettings/{id}/{document=**} { allow read, write: if false; }
    match /settings/{id}/{document=**}    { allow read, write: if false; }

    // ── 기본 거부 ──────────────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
