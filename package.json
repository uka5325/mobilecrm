{
  "name": "nextjs",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "tsx --test tests/units.test.ts",
    "test:rules": "firebase emulators:exec --only firestore \"tsx --test tests/rules.test.ts\"",
    "test:storage": "firebase emulators:exec --project demo-mobilecrm-rules --only firestore,auth,storage \"tsx --test tests/storage.rules.test.ts\"",
    "test:api": "firebase emulators:exec --project demo-mobilecrm-rules --only firestore,auth \"tsx --test tests/api/*.test.ts\"",
    "backfill:invoice-links": "tsx scripts/backfill-invoice-reservation-links.ts"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@grpc/grpc-js": "^1.14.4",
    "@grpc/proto-loader": "^0.8.1",
    "firebase": "^11.0.0",
    "firebase-admin": "^13.10.0",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^4.0.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "firebase-tools": "^15.22.4",
    "tailwindcss": "^4",
    "tsx": "^4.19.2",
    "typescript": "^5"
  }
}
